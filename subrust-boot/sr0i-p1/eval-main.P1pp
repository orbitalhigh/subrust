# eval-main.P1pp — entry for the P1pp sr0i. Reads the PROGRAM from stdin
# (brk heap), lexes, parses (p_program), and runs main (e_run_main). Exit code
# = g_trap (0 ok, 1 trapped), matching the C sr0i's return. Heap adds the
# locals stack after the parser tables: g_loctok@+868352 (32768), g_locval@
# +901120 (32768); total 933888.

%fn(p1_main, 32, {
    %st(s0, sp, 0)
    %li(a0, 0) %call(&sys_brk) %mov(s0, a0)
    %la(t0, &g_src)     %st(s0, t0, 0)
    %li(t1, 65536)  %add(t1, s0, t1) %la(t0, &g_tok)     %st(t1, t0, 0)
    %li(t1, 327680) %add(t1, s0, t1) %la(t0, &g_node)    %st(t1, t0, 0)
    %li(t1, 786432) %add(t1, s0, t1) %la(t0, &g_fn)      %st(t1, t0, 0)
    %li(t1, 819200) %add(t1, s0, t1) %la(t0, &g_fnptok)  %st(t1, t0, 0)
    %li(t1, 851968) %add(t1, s0, t1) %la(t0, &g_const)   %st(t1, t0, 0)
    %li(t1, 868352) %add(t1, s0, t1) %la(t0, &g_loctok)  %st(t1, t0, 0)
    %li(t1, 901120) %add(t1, s0, t1) %la(t0, &g_locval)  %st(t1, t0, 0)
    %li(t1, 933888) %add(t1, s0, t1) %la(t0, &g_argstk)  %st(t1, t0, 0)
    %li(t1, 966656) %add(a0, s0, t1) %call(&sys_brk)     # reserve
    %li(s0, 0)                                           # srcn
:.rd
    %li(t1, 65536) %sub(a2, t1, s0) %beqz(a2, &.rdd)
    %la(t0, &g_src) %ld(a1, t0, 0) %add(a1, a1, s0)
    %li(a0, 0) %call(&sys_read)
    %beqz(a0, &.rdd) %bltz(a0, &.rdd)
    %add(s0, s0, a0) %b(&.rd)
:.rdd
    %la(t0, &g_srcn) %st(s0, t0, 0)
    %call(&lex)
    %call(&p_program)
    %li(t1, 0) %la(t0, &g_trap)   %st(t1, t0, 0)
    %li(t1, 0) %la(t0, &g_signal) %st(t1, t0, 0)
    %li(t1, 0) %la(t0, &g_argsp)  %st(t1, t0, 0)
    %call(&e_run_main)
    %la(t0, &g_trap) %ld(a0, t0, 0)                      # exit code = g_trap
    %ld(s0, sp, 0)
})

:ELF_end
