## token is a tight TOK_LPAREN (i.e. the current token is a paren-call
## form). Read by directive/builtin sub-handlers that gate on paren form
## (%select, %str, %bytes, %local, !@$% arith, user-macro paren call).
:proc_has_paren
ZERO8
:macros_end
ZERO8
:macro_body_end
ZERO8
:def_m_ptr
ZERO8
