##   df_suffix_ptr/_len      — current synthesized field suffix
##   df_value                — index * stride for this macro's body
##   df_name_len             — base_len + 1 + suffix_len
##   df_digit_count/_cursor  — df_render_decimal output
:df_stride
ZERO8
